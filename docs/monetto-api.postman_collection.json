    {
      "name": "02 Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register"
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User {{run_id}}\",\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const runId = String(Date.now());",
                  "pm.collectionVariables.set('run_id', runId);",
                  "pm.collectionVariables.set('user_email', `postman-${runId}@example.com`);",
                  "pm.collectionVariables.set('user_password', 'Strong123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const json = pm.response.json();",
                  "pm.test('Registered user has no hashed password', function () { pm.expect(json).to.not.have.property('hashed_password'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login"
            },
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.test('Bearer token returned', function () { pm.expect(json.token_type).to.eql('bearer'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/me"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const json = pm.response.json();",
                  "pm.expect(json.name).to.be.a('string').and.not.empty;",
                  "pm.expect(json.email).to.eql(pm.collectionVariables.get('user_email'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 Categories",
      "item": [
        {
          "name": "GET /api/categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
