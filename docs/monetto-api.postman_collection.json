          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const data = pm.response.json();",
                  "const income = data.find((category) => category.type === 'INCOME');",
                  "const expense = data.find((category) => category.type === 'EXPENSE');",
                  "pm.expect(income, 'income category').to.exist;",
                  "pm.expect(expense, 'expense category').to.exist;",
                  "pm.collectionVariables.set('income_category_id', income.id);",
                  "pm.collectionVariables.set('expense_category_id', expense.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/categories?type=INCOME",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/categories?type=INCOME"
