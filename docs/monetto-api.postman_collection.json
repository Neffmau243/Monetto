    {
      "name": "01 Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/health"
            },
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "pm.test('Database is ok', function () { pm.expect(pm.response.json().database).to.eql('ok'); });"
                ]
              }
            }
          ]
        }
      ]
